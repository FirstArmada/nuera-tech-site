# This is a build-less static site — nothing here should be committed.
node_modules/
package.json
package-lock.json
.vercel/
.wrangler/
.DS_Store
*.log

# Server code under cloud/ has its own manifests and must be tracked, even
# though the root site stays build-less. (node_modules stays ignored below.)
!cloud/**/package.json
!cloud/**/package-lock.json
